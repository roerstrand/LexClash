@using OrdSpel.Shared.DTOs
@using OrdSpel.UI.Services
@inject GameService GameService
@inject IJSRuntime JS

@if (_isLoading)
{
    <p class="text-muted">Loading history...</p>
}
else if (_games.Count == 0)
{
    <p class="text-muted">No completed games found.</p>
}
else
{
    <div style="display:flex;flex-direction:column;gap:1rem;">
        @foreach (var game in _games)
        {
            <div style="
                background:
                    radial-gradient(ellipse 130% 70% at 50% -10%, rgba(184,212,227,0.38) 0%, transparent 60%),
                    rgba(255,255,255,0.88);
                backdrop-filter: blur(12px);
                border: 1px solid rgba(255,255,255,0.72);
                border-radius: var(--radius);
                padding: 1.25rem;
                box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 2px 8px rgba(102,16,31,0.09), 0 8px 28px rgba(102,16,31,0.12), 0 20px 44px rgba(102,16,31,0.07);
                transition: box-shadow 0.25s cubic-bezier(0.4,0,0.2,1), transform 0.25s cubic-bezier(0.4,0,0.2,1);
            ">
                <div>

                    @* Header: game code + date *@
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;flex-wrap:wrap;gap:0.5rem;">
                        <span style="font-family:'JetBrains Mono',monospace;font-size:1.3rem;font-weight:700;letter-spacing:0.12em;color:var(--accent);">
                            @game.GameCode
                        </span>
                        <small class="text-muted">@game.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                    </div>

                    @* Category *@
                    <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--muted);margin-bottom:0.75rem;">
                        @game.CategoryName
                    </div>

                    @* Winner *@
                    @if (game.WinnerUserId == null)
                    {
                        <div class="alert alert-info" style="padding:0.6rem 1rem;margin-bottom:0.75rem;">It's a draw</div>
                    }
                    else
                    {
                        <div class="alert alert-success" style="padding:0.6rem 1rem;margin-bottom:0.75rem;">
                            🏆 @(game.WinnerUsername ?? "Unknown") wins
                        </div>
                    }

                    @* Players *@
                    <ul class="list-group list-group-flush" style="margin-bottom:1rem;">
                        @foreach (var player in game.Players.OrderByDescending(p => p.TotalScore))
                        {
                            var isWinner = player.UserId == game.WinnerUserId;
                            <li class="list-group-item d-flex justify-content-between @(isWinner ? "list-group-item-success" : "")">
                                <span style="font-weight:@(isWinner ? "700" : "400");font-size:1rem;">
                                    @(player.Username ?? $"Player {player.PlayerOrder}")
                                </span>
                                <span class="badge @(isWinner ? "bg-success" : "bg-primary")"
                                      style="font-size:0.9rem;padding:0.4em 0.7em;">
                                    @player.TotalScore p
                                </span>
                            </li>
                        }
                    </ul>

                    <button class="btn btn-outline-danger btn-sm"
                            disabled="@(_deletingCode == game.GameCode)"
                            @onclick="() => DeleteGame(game.GameCode)">
                        @(_deletingCode == game.GameCode ? "Deleting..." : "Delete")
                    </button>
                </div>
            </div>
        }
    </div>
}


@code {
    private List<GameSummaryDto> _games = new();
    private bool _isLoading = true;
    private string? _deletingCode;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _games = await GameService.GetGameHistoryAsync();
        }
        catch { }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task DeleteGame(string gameCode)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this game from history?");
        if (!confirmed) return;

        _deletingCode = gameCode;
        try
        {
            var ok = await GameService.DeleteGameAsync(gameCode);
            if (ok)
                _games.RemoveAll(g => g.GameCode == gameCode);
        }
        catch { }
        finally
        {
            _deletingCode = null;
        }
    }
}
