@*
    DEPENDENCIES NEEDED BEFORE THIS COMPONENT IS FULLY FUNCTIONAL:

    1. GET /api/games/{code}/status  (TEAM-6 or backend responsible)
    2. POST /api/games/{code}/turns  (TEAM-6)
    3. SignalR event "TurnUpdated"   (TEAM-6 or hub builder)
*@
@using OrdSpel.Shared
@using OrdSpel.Shared.DTOs
@using OrdSpel.UI.Services
@using Microsoft.AspNetCore.SignalR.Client

@inject GameService GameService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject IConfiguration Configuration

@implements IAsyncDisposable

@if (_isLoading)
{
    <p class="text-muted">Loading game...</p>
}
else if (_gameStatus is null)
{
    <p class="text-danger">Could not load game. Check the game code and try again.</p>
}
else
{
    @* Header *@
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
        <h4 style="margin:0;color:var(--muted);font-weight:500;letter-spacing:0.04em;font-size:0.9rem;text-transform:uppercase;">Game in progress</h4>
        <span class="badge bg-secondary" style="font-size:0.9rem;">Round @_gameStatus.CurrentRound</span>
    </div>

    @if (_gameStatus.LastTurnWasPass)
    {
        <div class="alert alert-warning" style="margin-bottom:1.25rem;">
            <strong>Opponent passed!</strong> New random word: <strong>@_gameStatus.LastWord</strong>
        </div>
    }

    @* Current word panel *@
    <div style="
        background:
            radial-gradient(ellipse 120% 80% at 50% -10%, rgba(184,212,227,0.45) 0%, transparent 65%),
            rgba(255,255,255,0.88);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.72);
        border-radius: var(--radius);
        padding: 1.75rem 1.5rem;
        margin-bottom: 1.25rem;
        text-align: center;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 2px 8px rgba(102,16,31,0.09), 0 8px 28px rgba(102,16,31,0.12), 0 20px 44px rgba(102,16,31,0.07);
        transition: box-shadow 0.25s cubic-bezier(0.4,0,0.2,1);
    ">
        <div style="font-size:0.75rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.75rem;font-weight:600;">Current word</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:2.2rem;font-weight:700;color:var(--text);margin-bottom:0.75rem;word-break:break-all;letter-spacing:0.04em;">@CurrentWord</div>
        <div style="font-size:1rem;color:var(--muted);">
            Next word must start with
            <span style="
                font-family:'JetBrains Mono',monospace;
                font-size:1.6rem;
                font-weight:700;
                color:var(--warning);
                margin-left:0.4rem;
                display:inline-block;
                background: radial-gradient(ellipse 120% 100% at 50% 50%, rgba(138,96,16,0.1) 0%, transparent 70%);
                padding: 0 0.3rem;
                border-radius: 6px;
            ">'@RequiredLetter'</span>
        </div>
        <div style="margin-top:0.6rem;font-size:0.8rem;color:var(--muted);opacity:0.7;">Start word: @_gameStatus.StartWord</div>
    </div>

    @* Input or waiting *@
    <div style="margin-bottom:1.5rem;">
        @if (_gameStatus.CurrentTurnUserId == AuthState.UserId)
        {
            <div class="alert alert-success" style="margin-bottom:1rem;text-align:center;font-size:1.05rem;">
                <strong>Your turn!</strong>
            </div>

            <input class="form-control"
                   style="width:100%;margin-bottom:0.75rem;font-size:1.1rem;text-align:center;letter-spacing:0.02em;"
                   placeholder="Type a word..."
                   @bind="_wordInput"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown"
                   disabled="@_isSubmitting" />

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                <button class="btn btn-primary"
                        style="width:100%;"
                        @onclick="SubmitWord"
                        disabled="@(string.IsNullOrWhiteSpace(_wordInput) || _isSubmitting)">
                    Submit
                </button>
                <button class="btn btn-outline-warning"
                        style="width:100%;"
                        @onclick="PassTurn"
                        disabled="@_isSubmitting">
                    Pass (-5p)
                </button>
            </div>

            @if (!string.IsNullOrEmpty(_submitError))
            {
                <p class="text-danger" style="margin-top:0.75rem;text-align:center;">@_submitError</p>
            }
        }
        else
        {
            <div class="alert alert-secondary" style="text-align:center;font-size:1.05rem;">
                Waiting for opponent...
            </div>
        }
    </div>

    @* Scoreboard *@
    <div>
        <h5 style="font-size:0.82rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--muted);margin-bottom:0.75rem;font-weight:600;">Score</h5>
        <ul class="list-group">
            @foreach (var player in _gameStatus.Players)
            {
                var isCurrentTurn = player.UserId == _gameStatus.CurrentTurnUserId;
                <li class="list-group-item d-flex justify-content-between align-items-center @(isCurrentTurn ? "active" : "")">
                    <span>
                        @if (isCurrentTurn) { <strong>▶ </strong> }
                        @(player.Username ?? $"Player {player.PlayerOrder}")
                    </span>
                    <span class="badge bg-primary rounded-pill" style="font-size:0.95rem;">@player.TotalScore p</span>
                </li>
            }
        </ul>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public string GameCode { get; set; } = string.Empty;

    private GameStatusDto? _gameStatus;
    private bool _isLoading = true;

    private string _wordInput = string.Empty;
    private string _submitError = string.Empty;
    private bool _isSubmitting = false;

    private string CurrentWord => _gameStatus == null ? string.Empty
        : string.IsNullOrEmpty(_gameStatus.LastWord) ? _gameStatus.StartWord
        : _gameStatus.LastWord;

    private char RequiredLetter => CurrentWord.Length > 0 ? CurrentWord[^1] : '?';

    private HubConnection? _hubConnection;
    private CancellationTokenSource? _pollCts;

    protected override async Task OnParametersSetAsync()
    {
        await StopPollingAsync();
        await DisposeHubAsync();

        _isLoading = true;
        _gameStatus = await GameService.GetGameStatusAsync(GameCode);
        _isLoading = false;

        await StartHubAsync();
    }

    private async Task StartHubAsync()
    {
        if (string.IsNullOrWhiteSpace(GameCode))
            return;

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(new Uri(new Uri(Configuration["ConnectionStrings:ApiBaseUrl"]!), "hubs/game"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On("TurnUpdated", async (string gameCode) =>
        {
            if (string.Equals(gameCode, GameCode, StringComparison.OrdinalIgnoreCase))
            {
                _gameStatus = await GameService.GetGameStatusAsync(GameCode);
                await InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.Reconnected += async _ =>
        {
            await StopPollingAsync();
            _gameStatus = await GameService.GetGameStatusAsync(GameCode);
            await InvokeAsync(StateHasChanged);
        };

        _hubConnection.Closed += async _ => { await StartPollingAsync(); };

        try
        {
            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("JoinGame", GameCode);
        }
        catch { await StartPollingAsync(); }
    }

    private async Task StartPollingAsync()
    {
        if (_pollCts is not null) return;
        _pollCts = new CancellationTokenSource();
        var ct = _pollCts.Token;
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(3));
            while (await timer.WaitForNextTickAsync(ct))
            {
                _gameStatus = await GameService.GetGameStatusAsync(GameCode);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private Task StopPollingAsync()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollCts = null;
        return Task.CompletedTask;
    }

    private async Task DisposeHubAsync()
    {
        if (_hubConnection is null) return;
        try { await _hubConnection.DisposeAsync(); }
        finally { _hubConnection = null; }
    }

    public async ValueTask DisposeAsync()
    {
        await StopPollingAsync();
        await DisposeHubAsync();
    }

    private async Task SubmitWord()
    {
        if (string.IsNullOrWhiteSpace(_wordInput) || _isSubmitting) return;
        _submitError = string.Empty;
        _isSubmitting = true;
        var dto = new TurnRequestDto { Word = _wordInput.Trim(), PassedTurn = false };
        var (result, error) = await GameService.SubmitTurnAsync(GameCode, dto);
        if (error != null) _submitError = error;
        else _wordInput = string.Empty;
        _isSubmitting = false;
    }

    private async Task PassTurn()
    {
        if (_isSubmitting) return;
        _submitError = string.Empty;
        _isSubmitting = true;
        var dto = new TurnRequestDto { Word = null, PassedTurn = true };
        var (result, error) = await GameService.SubmitTurnAsync(GameCode, dto);
        if (error != null) _submitError = error;
        _isSubmitting = false;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SubmitWord();
    }
}
