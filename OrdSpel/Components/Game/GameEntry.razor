@using OrdSpel.Shared.DTOs
@using OrdSpel.Shared.GameDTOs
@using OrdSpel.UI.Services

@inject GameService GameService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<div style="display:flex;flex-direction:column;gap:1.25rem;">

    @* Create game *@
    <div style="
        background:
            radial-gradient(ellipse 130% 70% at 50% -10%, rgba(184,212,227,0.4) 0%, transparent 60%),
            rgba(255,255,255,0.88);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.72);
        border-radius: var(--radius);
        padding: 1.5rem;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 2px 8px rgba(102,16,31,0.09), 0 8px 28px rgba(102,16,31,0.12), 0 20px 44px rgba(102,16,31,0.07);
        transition: box-shadow 0.25s cubic-bezier(0.4,0,0.2,1);
    ">
        <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-bottom:1.25rem;font-weight:600;">Create game</div>

        <label class="form-label" style="display:block;margin-bottom:0.4rem;">Category</label>
        <select id="categorySelect" @bind="_categoryId" class="form-control" style="margin-bottom:1.1rem;">
            <option value="0">Choose category...</option>
            @foreach (var category in _categories)
            {
                <option value="@category.Id">@category.Name</option>
            }
        </select>

        @if (!string.IsNullOrEmpty(_createError))
        {
            <div class="alert alert-danger" style="margin-bottom:0.75rem;" id="createError">@_createError</div>
        }

        <button id="createGameButton" class="btn btn-primary" style="width:100%;" @onclick="CreateGame">Create game</button>
    </div>

    @* Join game *@
    <div style="
        background:
            radial-gradient(ellipse 130% 70% at 50% -10%, rgba(184,212,227,0.4) 0%, transparent 60%),
            rgba(255,255,255,0.88);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.72);
        border-radius: var(--radius);
        padding: 1.5rem;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 2px 8px rgba(102,16,31,0.09), 0 8px 28px rgba(102,16,31,0.12), 0 20px 44px rgba(102,16,31,0.07);
        transition: box-shadow 0.25s cubic-bezier(0.4,0,0.2,1);
    ">
        <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-bottom:1.25rem;font-weight:600;">Join game</div>

        <label class="form-label" style="display:block;margin-bottom:0.4rem;">Game code</label>
        <input id="gameCodeInput"
               @bind="_joinCode"
               type="text"
               inputmode="numeric"
               placeholder="123456"
               maxlength="6"
               class="form-control"
               style="font-family:'JetBrains Mono',monospace;letter-spacing:0.18em;font-size:1.3rem;text-align:center;margin-bottom:1.1rem;" />

        @if (!string.IsNullOrEmpty(_joinError))
        {
            <div class="alert alert-danger" style="margin-bottom:0.75rem;" id="joinError">@_joinError</div>
        }

        <button id="joinGameButton" class="btn btn-outline-secondary" style="width:100%;" @onclick="JoinGame">Join</button>
    </div>

</div>

@code {
    private int _categoryId;
    private string _joinCode = string.Empty;
    private string _createError = string.Empty;
    private string _joinError = string.Empty;
    private GameSessionResponseDto? _createdSession;
    private List<CategoryDto> _categories = new();

    protected override async Task OnInitializedAsync()
    {
        _categories = await GameService.GetCategoriesAsync<CategoryDto>();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("eval", "document.body.setAttribute('blazor-ready', 'true')");
    }

    private async Task CreateGame()
    {
        _createError = string.Empty;
        _createdSession = null;

        if (_categoryId <= 0)
        {
            _createError = "Please select a category.";
            return;
        }

        var dto = new CreateGameDto { CategoryId = _categoryId };
        var result = await GameService.CreateGameAsync(dto);

        if (result == null)
        {
            _createError = "Something went wrong. Please try again.";
            return;
        }

        _createdSession = result;
        NavigationManager.NavigateTo($"/game/{result.GameCode}");
    }

    private async Task JoinGame()
    {
        _joinError = string.Empty;

        if (string.IsNullOrWhiteSpace(_joinCode))
        {
            _joinError = "Please enter a game code.";
            return;
        }

        var dto = new JoinGameDto { GameCode = _joinCode };
        var (result, error) = await GameService.JoinGameAsync(dto);

        if (error != null)
        {
            _joinError = error;
            return;
        }

        NavigationManager.NavigateTo($"/game/{result!.GameCode}");
    }
}
