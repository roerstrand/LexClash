@using OrdSpel.Shared.DTOs
@using OrdSpel.Shared.GameDTOs
@using OrdSpel.UI.Services

@inject GameService GameService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;max-width:640px;">

    <div style="background:#2a2a3e;border:1px solid #44445a;padding:1.5rem;">
        <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;color:#9999bb;margin-bottom:1.25rem;">Skapa spel</div>

        <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;color:#9999bb;margin-bottom:0.4rem;">Kategori</label>
        <select id="categorySelect" @bind="_categoryId" class="form-control" style="margin-bottom:1rem;">
            <option value="0">Välj kategori...</option>
            @foreach (var category in _categories)
            {
                <option value="@category.Id">@category.Name</option>
            }
        </select>

        @if (!string.IsNullOrEmpty(_createError))
        {
            <div class="alert alert-danger" style="margin-bottom:0.75rem;font-size:0.82rem;" id="createError">@_createError</div>
        }

        <button id="createGameButton" class="btn btn-primary" style="width:100%;" @onclick="CreateGame">Skapa</button>
    </div>

    <div style="background:#2a2a3e;border:1px solid #44445a;padding:1.5rem;">
        <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;color:#9999bb;margin-bottom:1.25rem;">Gå med i spel</div>

        <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;color:#9999bb;margin-bottom:0.4rem;">Spelkod</label>
        <input id="gameCodeInput"
               @bind="_joinCode"
               type="text"
               placeholder="123456"
               maxlength="6"
               class="form-control"
               style="font-family:'JetBrains Mono',monospace;letter-spacing:0.15em;font-size:1.1rem;margin-bottom:1rem;" />

        @if (!string.IsNullOrEmpty(_joinError))
        {
            <div class="alert alert-danger" style="margin-bottom:0.75rem;font-size:0.82rem;" id="joinError">@_joinError</div>
        }

        <button id="joinGameButton" class="btn btn-outline-secondary" style="width:100%;" @onclick="JoinGame">Anslut</button>
    </div>

</div>

@code {
    private int _categoryId;
    private string _joinCode = string.Empty;
    private string _createError = string.Empty;
    private string _joinError = string.Empty;
    private GameSessionResponseDto? _createdSession;
    private List<CategoryDto> _categories = new();

    protected override async Task OnInitializedAsync()
    {
        _categories = await GameService.GetCategoriesAsync<CategoryDto>();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("eval", "document.body.setAttribute('blazor-ready', 'true')");
    }

    private async Task CreateGame()
    {
        _createError = string.Empty;
        _createdSession = null;

        if (_categoryId <= 0)
        {
            _createError = "Välj en kategori.";
            return;
        }

        var dto = new CreateGameDto { CategoryId = _categoryId };
        var result = await GameService.CreateGameAsync(dto);

        if (result == null)
        {
            _createError = "Något gick fel. Försök igen.";
            return;
        }

        _createdSession = result;
        NavigationManager.NavigateTo($"/game/{result.GameCode}");
    }

    private async Task JoinGame()
    {
        _joinError = string.Empty;

        if (string.IsNullOrWhiteSpace(_joinCode))
        {
            _joinError = "Ange en spelkod.";
            return;
        }

        var dto = new JoinGameDto { GameCode = _joinCode };
        var (result, error) = await GameService.JoinGameAsync(dto);

        if (error != null)
        {
            _joinError = error;
            return;
        }

        NavigationManager.NavigateTo($"/game/{result!.GameCode}");
    }
}
