
@using OrdSpel.Shared.DTOs
@using OrdSpel.Shared.Enums
@inject OrdSpel.UI.Services.GameService GameService
@inject NavigationManager Navigation



<div class="container mt-4">

    @* Loading *@
    @if (_isLoading)
    {
        <p id="gameResultLoading" class="text-muted">Laddar resultat...</p>
    }

    @* If error is not null, show error message >>> "BackToGame" *@
    else if (_error is not null)
    {
        <div id="gameResultError" class="alert alert-danger">@_error</div>
        <button id="gameResultBackButton" class="btn btn-outline-secondary" @onclick="BackToGame">
            Tillbaka
        </button>
    }

    @* No error, but Result is null >>> "Back to Game" *@
    else if (_result is null)
    {
        <div id="gameResultError" class="alert alert-danger">Kunde inte ladda resultatet.</div>
        <button id="gameResultBackButton" class="btn btn-outline-secondary" @onclick="BackToGame">
            Tillbaka
        </button>
    }

    @* Loading is completed, Result is not null && Error is null >> Show SpelSlut & Result *@
    else
    {
        <div class="mb-4">
            <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.12em;color:#999;margin-bottom:0.25rem;">Spelslut</div>
            <h2 id="gameResultTitle" style="font-size:1.8rem;font-weight:700;letter-spacing:-0.02em;margin:0;">Resultat</h2>
        </div>

        @* Vinnarbanner *@
        <div class="mb-4">
            @if (string.IsNullOrWhiteSpace(_result.WinnerUserId))
            {
                <div id="gameResultWinner" class="alert alert-info text-center fs-4">
                    <strong>Oavgjort</strong>
                </div>
            }
            else
            {
                <div id="gameResultWinner" class="alert alert-success text-center fs-4">
                    <strong>@(GetWinnerName()) vinner</strong>
                </div>
            }
        </div>

        @* Poängtabell *@
        <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;color:#999;margin-bottom:0.75rem;" id="gameResultScoreboardTitle">
            Slutresultat
        </div>
        <ul id="gameResultScoreboard" class="list-group" style="max-width:420px;margin-bottom:2rem;">
            @foreach (var player in _result.Players.OrderByDescending(p => p.TotalScore))
            {
                var isWinner = player.UserId == _result.WinnerUserId;
                <li class="list-group-item d-flex justify-content-between align-items-center @(isWinner ? "list-group-item-success" : "")"
                    id="gameResultPlayer-@player.PlayerOrder">
                    <span style="font-weight:@(isWinner ? "700" : "400");">
                        @(player.Username ?? $"Spelare {player.PlayerOrder}")
                    </span>
                    <span class="badge @(isWinner ? "bg-success" : "bg-primary")" style="font-family:'JetBrains Mono',monospace;font-size:0.9rem;">
                        @player.TotalScore p
                    </span>
                </li>
            }
        </ul>

        <button id="gameResultBackButton" class="btn btn-primary" @onclick="BackToGame">
            Nytt spel
        </button>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string GameCode { get; set; } = string.Empty;

    private GameResultDto? _result;
    private bool _isLoading = true;
    private string? _error;



    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(GameCode))
        {
            _error = "Game code saknas.";
            _isLoading = false;
            return;
        }

        _isLoading = true;
        _error = null;
        _result = null;

        try
        {
            // Call API 
            _result = await GameService.GetGameResultAsync(GameCode);

            // If result is not null, but game has finished yet 
            if (_result is not null && _result.Status != GameStatus.GameFinished)
            {
                _error = "Spelet är inte avslutat ännu.";
            }
        }
        // Trow execption when calling API 
        catch (HttpRequestException)
        {
            _error = "Kunde inte hämta resultat från servern.";
        }

        // Keep Working even error occurs, but show error message to user and "Back to Game" button
        finally
        {
            _isLoading = false;
        }
    }



    private string GetWinnerName()
    {
        var winner = _result?.Players.FirstOrDefault(p => p.UserId == _result.WinnerUserId);
        return winner?.Username ?? $"Spelare {winner?.PlayerOrder}";
    }

    private void BackToGame()
    {
        Navigation.NavigateTo("/game");
    }
}
