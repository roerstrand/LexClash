@using OrdSpel.Shared.DTOs
@using OrdSpel.Shared.Enums
@inject OrdSpel.UI.Services.GameService GameService
@inject NavigationManager Navigation

@if (_isLoading)
{
    <p id="gameResultLoading" class="text-muted">Loading results...</p>
}
else if (_error is not null)
{
    <div id="gameResultError" class="alert alert-danger">@_error</div>
    <button id="gameResultBackButton" class="btn btn-outline-secondary" style="width:100%;" @onclick="BackToGame">
        Back
    </button>
}
else if (_result is null)
{
    <div id="gameResultError" class="alert alert-danger">Could not load results.</div>
    <button id="gameResultBackButton" class="btn btn-outline-secondary" style="width:100%;" @onclick="BackToGame">
        Back
    </button>
}
else
{
    <div style="margin-bottom:1.75rem;text-align:center;">
        <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);margin-bottom:0.4rem;">Game over</div>
        <h2 id="gameResultTitle" style="font-size:2rem;font-weight:700;letter-spacing:-0.02em;margin:0;">Results</h2>
    </div>

    @* Winner banner *@
    <div style="margin-bottom:1.5rem;">
        @if (string.IsNullOrWhiteSpace(_result.WinnerUserId))
        {
            <div id="gameResultWinner" class="alert alert-info" style="text-align:center;font-size:1.3rem;">
                <strong>It's a draw!</strong>
            </div>
        }
        else
        {
            <div id="gameResultWinner" class="alert alert-success" style="text-align:center;font-size:1.3rem;">
                <strong>🏆 @(GetWinnerName()) wins!</strong>
            </div>
        }
    </div>

    @* Score table *@
    <div style="
        background:
            radial-gradient(ellipse 130% 70% at 50% -10%, rgba(184,212,227,0.4) 0%, transparent 60%),
            rgba(255,255,255,0.88);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.72);
        border-radius: var(--radius);
        padding: 1.25rem 1.25rem 0.5rem;
        margin-bottom: 2rem;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 2px 8px rgba(102,16,31,0.09), 0 8px 28px rgba(102,16,31,0.12), 0 20px 44px rgba(102,16,31,0.07);
    ">
        <div id="gameResultScoreboardTitle" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-bottom:0.75rem;font-weight:600;">
            Final score
        </div>
        <ul id="gameResultScoreboard" class="list-group list-group-flush">
            @foreach (var player in _result.Players.OrderByDescending(p => p.TotalScore))
            {
                var isWinner = player.UserId == _result.WinnerUserId;
                <li class="list-group-item d-flex justify-content-between align-items-center @(isWinner ? "list-group-item-success" : "")"
                    id="gameResultPlayer-@player.PlayerOrder"
                    style="background:transparent;">
                    <span style="font-weight:@(isWinner ? "700" : "400");font-size:1.05rem;">
                        @(isWinner ? "🏆 " : "")@(player.Username ?? $"Player {player.PlayerOrder}")
                    </span>
                    <span class="badge @(isWinner ? "bg-success" : "bg-primary")" style="font-size:1rem;padding:0.5em 0.8em;">
                        @player.TotalScore p
                    </span>
                </li>
            }
        </ul>
    </div>

    <button id="gameResultBackButton" class="btn btn-primary" style="width:100%;" @onclick="BackToGame">
        New game
    </button>
}

@code {
    [Parameter, EditorRequired]
    public string GameCode { get; set; } = string.Empty;

    private GameResultDto? _result;
    private bool _isLoading = true;
    private string? _error;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(GameCode))
        {
            _error = "Game code is missing.";
            _isLoading = false;
            return;
        }

        _isLoading = true;
        _error = null;
        _result = null;

        try
        {
            _result = await GameService.GetGameResultAsync(GameCode);

            if (_result is not null && _result.Status != GameStatus.GameFinished)
            {
                _error = "The game has not ended yet.";
            }
        }
        catch (HttpRequestException)
        {
            _error = "Could not fetch results from the server.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetWinnerName()
    {
        var winner = _result?.Players.FirstOrDefault(p => p.UserId == _result.WinnerUserId);
        return winner?.Username ?? $"Player {winner?.PlayerOrder}";
    }

    private void BackToGame()
    {
        Navigation.NavigateTo("/game");
    }
}
