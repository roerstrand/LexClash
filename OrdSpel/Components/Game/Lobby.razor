
@using OrdSpel.Shared.DTOs
@using Microsoft.JSInterop

@inject IJSRuntime JS

@* For showing GameCode, Status, Number of Players, Category, StartWord, 
and a Start button if ready to start. Also includes a Copy button for the GameCode. *@


<div style="padding:0.5rem 0;">
    <h2 style="font-size:1rem;text-transform:uppercase;letter-spacing:0.12em;color:#9999bb;font-weight:500;margin-bottom:2rem;">Lobby</h2>

    @*   if GameCode us null >> Show massage... *@
    @if (string.IsNullOrWhiteSpace(GameCode))
    {
        <p id="lobbyNoCodeMessage" style="color:#9999bb;">Ingen spelkod hittades.</p>
    }

    @*   if there is GameCode, but Status is null>> Show massage... *@
    else if (Status is null)
    {
        <p style="color:#9999bb;">Laddar lobby...</p>
    }

    @*   if GameCode and Status is not null >>> Show details...GameCode, Copy-button *@
    else
    {
        <div style="margin-bottom:2rem;">
            <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;color:#9999bb;margin-bottom:0.5rem;">Spelkod</div>
            <div style="display:flex;align-items:center;gap:1rem;">
                <span style="font-family:'JetBrains Mono',monospace;font-size:2.2rem;font-weight:700;letter-spacing:0.2em;color:#e8e8f0;">@GameCode</span>
                <button id="copyGameCodeButton"
                        type="button"
                        class="btn btn-outline-secondary btn-sm"
                        @onclick="CopyGameCodeAsync">
                    @(_copyMessage ?? "Kopiera")
                </button>
            </div>
        </div>

        @*   Show the data from DTO *@
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:2rem;">
            <div style="background:#2a2a3e;border:1px solid #9999bb45a;padding:1rem;">
                <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:#9999bb;margin-bottom:0.25rem;">Kategori</div>
                <div id="lobbyCategory" style="color:#e8e8f0;font-weight:500;">@Status.CategoryName</div>
            </div>
            <div style="background:#2a2a3e;border:1px solid #9999bb45a;padding:1rem;">
                <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:#9999bb;margin-bottom:0.25rem;">Spelare</div>
                <div id="lobbyPlayers" style="color:#e8e8f0;font-weight:500;">@Status.PlayerCount / @Status.MaxPlayers</div>
            </div>
            <div style="background:#2a2a3e;border:1px solid #9999bb45a;padding:1rem;">
                <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:#9999bb;margin-bottom:0.25rem;">Startord</div>
                <div id="lobbyStartWord" style="font-family:'JetBrains Mono',monospace;color:#e8e8f0;font-weight:600;">@Status.StartWord</div>
            </div>
            <div style="background:#2a2a3e;border:1px solid #9999bb45a;padding:1rem;">
                <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:#9999bb;margin-bottom:0.25rem;">Status</div>
                <div id="lobbyStatus" style="color:#e8e8f0;font-weight:500;">@Status.Status</div>
            </div>
        </div>

        @* If IsReadyToStart= true >>> Show StartGame-button *@
        @if (Status.IsReadyToStart)
        {
            <div style="display:flex;align-items:center;justify-content:space-between;background:#061a0e;border:1px solid #114422;padding:1rem 1.25rem;">
                <span style="color:#44ff88;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.06em;">Redo att starta (@Status.PlayerCount/@Status.MaxPlayers)</span>
                <button id="startGameButton"
                        type="button"
                        class="btn btn-success btn-sm"
                        @onclick="OnStartClicked">
                    Starta
                </button>
            </div>
        }

        @* If IsReadyToStart= false >>> Waiting for players*@
        else
        {
            <div style="background:#2a2a3e;border:1px solid #9999bb45a;padding:1rem 1.25rem;color:#9999bb;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.06em;">
                Väntar på spelare... (@Status.PlayerCount/@Status.MaxPlayers)
            </div>
        }
    }
</div>



@code {
    [Parameter, EditorRequired]
    public string GameCode { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public GameLobbyStatusDto? Status { get; set; }

    [Parameter]
    public EventCallback OnStart { get; set; }

    private string? _copyMessage;

    private async Task CopyGameCodeAsync()
    {
        if (string.IsNullOrWhiteSpace(GameCode))
            return;

        _copyMessage = null;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", GameCode);
            _copyMessage = "Copied";
        }
        catch (JSException)
        {
            _copyMessage = "Kunde inte kopiera";
        }

        _ = Task.Run(async () =>
        {
            await Task.Delay(TimeSpan.FromSeconds(2));
            _copyMessage = null;
            await InvokeAsync(StateHasChanged);
        });
    }

    private async Task OnStartClicked()
    {
        if (OnStart.HasDelegate)
        {
            await OnStart.InvokeAsync();
        }
    }
}

