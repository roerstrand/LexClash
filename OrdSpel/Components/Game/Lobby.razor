@using OrdSpel.Shared.DTOs
@using Microsoft.JSInterop

@inject IJSRuntime JS

@* For showing GameCode, Status, Number of Players, Category, StartWord,
and a Start button if ready to start. Also includes a Copy button for the GameCode. *@

<div style="padding:0.5rem 0;">
    <h2 style="font-size:0.9rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);font-weight:600;margin-bottom:1.75rem;">Lobby</h2>

    @if (string.IsNullOrWhiteSpace(GameCode))
    {
        <p id="lobbyNoCodeMessage" style="color:var(--muted);">No game code found.</p>
    }
    else if (Status is null)
    {
        <p style="color:var(--muted);">Loading lobby...</p>
    }
    else
    {
        @* Game code *@
        <div style="margin-bottom:2rem;text-align:center;">
            <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-bottom:0.75rem;font-weight:600;">Game code — share with your opponent</div>
            <div style="
                font-family:'JetBrains Mono',monospace;
                font-size:3rem;
                font-weight:700;
                letter-spacing:0.25em;
                color:var(--accent);
                margin-bottom:1rem;
                background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(184, 212, 227, 0.12) 0%, transparent 70%);
                padding:0.5rem 0;
                border-radius:var(--radius);">@GameCode</div>
            <button id="copyGameCodeButton"
                    type="button"
                    class="btn btn-outline-secondary btn-sm"
                    @onclick="CopyGameCodeAsync">
                @(_copyMessage ?? "📋 Copy code")
            </button>
        </div>

        @* Info tiles *@
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:1.75rem;">

            @* Category *@
            <div id="lobbyCategory" style="background:radial-gradient(ellipse 130% 80% at 50% -15%,rgba(184,212,227,0.35) 0%,transparent 65%),rgba(255,255,255,0.82);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.72);border-radius:var(--radius);padding:1rem;text-align:center;box-shadow:inset 0 1px 0 rgba(255,255,255,0.9),0 2px 8px rgba(102,16,31,0.09),0 8px 28px rgba(102,16,31,0.1),0 18px 40px rgba(102,16,31,0.06);transition:box-shadow 0.25s cubic-bezier(0.4,0,0.2,1),transform 0.25s cubic-bezier(0.4,0,0.2,1);">
                <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-bottom:0.4rem;font-weight:600;">Category</div>
                <div style="color:var(--text);font-weight:700;font-size:1.05rem;">@Status.CategoryName</div>
            </div>

            @* Players *@
            <div id="lobbyPlayers" style="background:radial-gradient(ellipse 130% 80% at 50% -15%,rgba(184,212,227,0.35) 0%,transparent 65%),rgba(255,255,255,0.82);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.72);border-radius:var(--radius);padding:1rem;text-align:center;box-shadow:inset 0 1px 0 rgba(255,255,255,0.9),0 2px 8px rgba(102,16,31,0.09),0 8px 28px rgba(102,16,31,0.1),0 18px 40px rgba(102,16,31,0.06);transition:box-shadow 0.25s cubic-bezier(0.4,0,0.2,1),transform 0.25s cubic-bezier(0.4,0,0.2,1);">
                <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-bottom:0.4rem;font-weight:600;">Players</div>
                <div style="color:var(--text);font-weight:700;font-size:1.2rem;">@Status.PlayerCount / @Status.MaxPlayers</div>
            </div>

            @* Start word *@
            <div id="lobbyStartWord" style="background:radial-gradient(ellipse 130% 80% at 50% -15%,rgba(184,212,227,0.35) 0%,transparent 65%),rgba(255,255,255,0.82);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.72);border-radius:var(--radius);padding:1rem;text-align:center;box-shadow:inset 0 1px 0 rgba(255,255,255,0.9),0 2px 8px rgba(102,16,31,0.09),0 8px 28px rgba(102,16,31,0.1),0 18px 40px rgba(102,16,31,0.06);transition:box-shadow 0.25s cubic-bezier(0.4,0,0.2,1),transform 0.25s cubic-bezier(0.4,0,0.2,1);">
                <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-bottom:0.4rem;font-weight:600;">Start word</div>
                <div style="font-family:'JetBrains Mono',monospace;color:var(--text);font-weight:700;font-size:1.1rem;">@Status.StartWord</div>
            </div>

            @* Status *@
            <div id="lobbyStatus" style="background:radial-gradient(ellipse 130% 80% at 50% -15%,rgba(184,212,227,0.35) 0%,transparent 65%),rgba(255,255,255,0.82);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.72);border-radius:var(--radius);padding:1rem;text-align:center;box-shadow:inset 0 1px 0 rgba(255,255,255,0.9),0 2px 8px rgba(102,16,31,0.09),0 8px 28px rgba(102,16,31,0.1),0 18px 40px rgba(102,16,31,0.06);transition:box-shadow 0.25s cubic-bezier(0.4,0,0.2,1),transform 0.25s cubic-bezier(0.4,0,0.2,1);">
                <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-bottom:0.4rem;font-weight:600;">Status</div>
                <div style="color:var(--text);font-weight:600;font-size:0.95rem;">@Status.Status</div>
            </div>

        </div>

        @* Start / waiting *@
        @if (Status.IsReadyToStart)
        {
            <div style="
                background:
                    radial-gradient(ellipse 120% 70% at 50% -10%, rgba(157,232,138,0.18) 0%, transparent 65%),
                    rgba(255,255,255,0.82);
                backdrop-filter: blur(10px);
                border: 1px solid rgba(157,232,138,0.3);
                border-radius: var(--radius);
                padding: 1.25rem;
                text-align: center;
                box-shadow: inset 0 1px 0 rgba(255,255,255,0.85), 0 2px 8px rgba(40,120,40,0.1), 0 8px 28px rgba(40,120,40,0.12), 0 20px 44px rgba(40,120,40,0.07);
            ">
                <div style="color:var(--success);font-size:0.85rem;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:1rem;font-weight:600;">
                    Ready to start (@Status.PlayerCount/@Status.MaxPlayers)
                </div>
                <button id="startGameButton"
                        type="button"
                        class="btn btn-success"
                        style="width:100%;"
                        @onclick="OnStartClicked">
                    Start game
                </button>
            </div>
        }
        else
        {
            <div style="
                background:
                    radial-gradient(ellipse 120% 70% at 50% -10%, rgba(184,212,227,0.25) 0%, transparent 65%),
                    rgba(255,255,255,0.72);
                backdrop-filter: blur(10px);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: 1.25rem;
                text-align: center;
                color: var(--muted);
                font-size: 0.9rem;
                text-transform: uppercase;
                letter-spacing: 0.06em;
                box-shadow: inset 0 1px 0 rgba(255,255,255,0.85), 0 2px 8px rgba(102,16,31,0.08), 0 8px 28px rgba(102,16,31,0.1), 0 20px 44px rgba(102,16,31,0.06);
            ">
                Waiting for opponent... (@Status.PlayerCount/@Status.MaxPlayers)
            </div>
        }
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string GameCode { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public GameLobbyStatusDto? Status { get; set; }

    [Parameter]
    public EventCallback OnStart { get; set; }

    private string? _copyMessage;

    private async Task CopyGameCodeAsync()
    {
        if (string.IsNullOrWhiteSpace(GameCode))
            return;

        _copyMessage = null;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", GameCode);
            _copyMessage = "✓ Copied!";
        }
        catch (JSException)
        {
            _copyMessage = "Could not copy";
        }

        _ = Task.Run(async () =>
        {
            await Task.Delay(TimeSpan.FromSeconds(2));
            _copyMessage = null;
            await InvokeAsync(StateHasChanged);
        });
    }

    private async Task OnStartClicked()
    {
        if (OnStart.HasDelegate)
        {
            await OnStart.InvokeAsync();
        }
    }
}
