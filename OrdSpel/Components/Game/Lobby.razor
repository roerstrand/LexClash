
@using OrdSpel.Shared.DTOs
@using Microsoft.JSInterop

@inject IJSRuntime JS

@* For showing GameCode, Status, Number of Players, Category, StartWord, 
and a Start button if ready to start. Also includes a Copy button for the GameCode. *@


<div class="container mt-4">
    <h2>Spellobby</h2>
  @*   if GameCode us null >> Show massage... *@
    @if (string.IsNullOrWhiteSpace(GameCode))
    {
        <p id="lobbyNoCodeMessage" class="text-muted">Ingen spelkod hittades.</p>
    }

    @*   if there is GameCode, but Status is null>> Show massage... *@
    else if (Status is null)
    {
        <p class="text-muted">Laddar lobbystatus...</p>
    }

    @*   if GameCode and Status is not null >>> Show details...GameCode, Copy-button *@
    else
    {
        <div class="mb-3">
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <div><strong>Spelkod:</strong> @GameCode</div>
                <button id="copyGameCodeButton"
                        type="button"
                        class="btn btn-sm btn-outline-secondary"
                        @onclick="CopyGameCodeAsync">
                    Copy
                </button>

                @* If copyMessage is not null >> "Copied / Kunde inte kopiera" *@
                @if (!string.IsNullOrWhiteSpace(_copyMessage))
                {
                    <span id="copyGameCodeMessage" class="text-muted">@_copyMessage</span>
                }
            </div>

            @*   Show the data from DTO *@
            <div id="lobbyStatus"><strong>Status:</strong> @Status.Status</div>
            <div id="lobbyPlayers"><strong>Spelare:</strong> @Status.PlayerCount / @Status.MaxPlayers</div>
            <div id="lobbyCategory"><strong>Kategori:</strong> @Status.CategoryName</div>
            <div id="lobbyStartWord"><strong>Startsord:</strong> @Status.StartWord</div>
        </div>

        @* If IsReadyToStart= true >>> Show StartGame-button *@
        @if (Status.IsReadyToStart)
        {
            <div class="alert alert-success d-flex justify-content-between align-items-center" role="alert">
                <span>Redo att starta! (@Status.PlayerCount/@Status.MaxPlayers)</span>
                <button id="startGameButton"
                        type="button"
                        class="btn btn-success"
                        @onclick="OnStartClicked">
                    Starta
                </button>
            </div>
        }

        @* If IsReadyToStart= false >>> Waiting for players*@
        else
        {
            <p class="text-muted">Väntar på spelare... (@Status.PlayerCount/@Status.MaxPlayers)</p>
        }
    }
</div>



@code {
    [Parameter, EditorRequired]
    public string GameCode { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public GameLobbyStatusDto? Status { get; set; }

    [Parameter]
    public EventCallback OnStart { get; set; }

    private string? _copyMessage;

    private async Task CopyGameCodeAsync()
    {
        if (string.IsNullOrWhiteSpace(GameCode))
            return;

        _copyMessage = null;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", GameCode);
            _copyMessage = "Copied";
        }
        catch (JSException)
        {
            _copyMessage = "Kunde inte kopiera";
        }

        _ = Task.Run(async () =>
        {
            await Task.Delay(TimeSpan.FromSeconds(2));
            _copyMessage = null;
            await InvokeAsync(StateHasChanged);
        });
    }

    private async Task OnStartClicked()
    {
        if (OnStart.HasDelegate)
        {
            await OnStart.InvokeAsync();
        }
    }
}

