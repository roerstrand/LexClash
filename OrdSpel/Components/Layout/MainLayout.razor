@namespace OrdSpel.UI.Components.Layout
@inherits LayoutComponentBase
@inject OrdSpel.UI.Services.AuthStateService AuthState
@inject NavigationManager Nav

@* ── Desktop sidebar ─────────────────────────────────────────── *@
<nav class="sidebar">

    <a href="/game" class="topbar-logo" style="margin-bottom:2rem;gap:0.75rem;">
        <div style="width:42px;height:42px;border-radius:10px;background:var(--accent);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 2px 8px rgba(255,93,115,0.4);">
            <span style="font-family:'JetBrains Mono',monospace;font-size:1.1rem;font-weight:700;color:#fff;line-height:1;letter-spacing:-0.02em;">LC</span>
        </div>
        <span style="font-family:'Fondamento',serif;font-size:1.3rem;font-weight:700;color:var(--text);letter-spacing:0.05em;">LexClash</span>
    </a>

    @if (AuthState.IsLoggedIn)
    {
        <div style="background:linear-gradient(135deg,rgba(255,93,115,0.18) 0%,rgba(255,93,115,0.06) 100%);border:1px solid var(--border2);border-radius:12px;padding:1rem 1.1rem;margin-bottom:0.75rem;">
            <div style="font-size:0.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.12em;font-weight:700;margin-bottom:0.3rem;">Logged in as</div>
            <div style="font-size:1.15rem;color:#fff;font-weight:800;letter-spacing:0.04em;word-break:break-all;">@AuthState.Username</div>
        </div>

        <a href="/game"
           class="nav-item-link @(ActiveClass("new"))"
           @onclick:preventDefault="true"
           @onclick='() => Navigate("/game")'>
            <span style="font-size:1.25rem;line-height:1;">🏠</span> Home
        </a>

        <a href="/game?tab=active"
           class="nav-item-link @(ActiveClass("active"))"
           @onclick:preventDefault="true"
           @onclick='() => Navigate("/game?tab=active")'>
            <span style="font-size:1.25rem;line-height:1;">🎮</span> Active games
        </a>

        <a href="/game?tab=history"
           class="nav-item-link @(ActiveClass("history"))"
           @onclick:preventDefault="true"
           @onclick='() => Navigate("/game?tab=history")'>
            <span style="font-size:1.25rem;line-height:1;">📋</span> Saved games
        </a>

        <div style="margin-top:auto;padding-top:1rem;border-top:1px solid var(--border);">
            <button class="btn-logout" @onclick="Logout">Log out</button>
        </div>
    }
    else
    {
        <a href="/" class="btn btn-primary" style="margin-bottom:0.5rem;text-align:left;width:100%;">Log in</a>
        <a href="/register" class="btn btn-outline-secondary" style="text-align:left;width:100%;">Register</a>
    }
</nav>

@* ── Mobile top bar ───────────────────────────────────────────── *@
<header class="topbar">
    <a href="/game" class="topbar-logo" style="gap:0.6rem;">
        <div style="width:34px;height:34px;border-radius:8px;background:var(--accent);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 2px 6px rgba(255,93,115,0.4);">
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.9rem;font-weight:700;color:#fff;line-height:1;letter-spacing:-0.02em;">LC</span>
        </div>
        <span style="font-family:'Fondamento',serif;font-size:1.15rem;font-weight:700;color:var(--text);letter-spacing:0.05em;">LexClash</span>
    </a>

    @if (AuthState.IsLoggedIn)
    {
        <span class="topbar-user" style="font-weight:600;color:var(--accent);font-size:0.9rem;">@AuthState.Username</span>
    }
    else
    {
        <a href="/" style="font-size:0.85rem;color:var(--muted);text-decoration:none;">Log in</a>
    }
</header>

@* ── Mobile bottom navigation ─────────────────────────────────── *@
<nav class="bottom-nav">
    @if (AuthState.IsLoggedIn)
    {
        <a href="/game" class="bottom-nav-item @(ActiveClass("new"))" @onclick:preventDefault="true" @onclick='() => Navigate("/game")'>
            <span class="bottom-nav-icon">🏠</span>
            <span>Home</span>
        </a>

        <a href="/game?tab=active" class="bottom-nav-item @(ActiveClass("active"))" @onclick:preventDefault="true" @onclick='() => Navigate("/game?tab=active")'>
            <span class="bottom-nav-icon">🎮</span>
            <span>Active</span>
        </a>

        <a href="/game?tab=history" class="bottom-nav-item @(ActiveClass("history"))" @onclick:preventDefault="true" @onclick='() => Navigate("/game?tab=history")'>
            <span class="bottom-nav-icon">📋</span>
            <span>Saved</span>
        </a>

        <button class="bottom-nav-item" @onclick="Logout">
            <span class="bottom-nav-icon">🚪</span>
            <span>Log out</span>
        </button>
    }
    else
    {
        <a href="/" class="bottom-nav-item @(Nav.Uri.EndsWith("/") || Nav.Uri.Contains("login") ? "nav-active" : "")">
            <span class="bottom-nav-icon">🔑</span>
            <span>Log in</span>
        </a>
        <a href="/register" class="bottom-nav-item @(Nav.Uri.Contains("register") ? "nav-active" : "")">
            <span class="bottom-nav-icon">✏️</span>
            <span>Register</span>
        </a>
    }
</nav>

@* ── Main content ─────────────────────────────────────────────── *@
<div class="main-content">
    @Body
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private string _currentTab = "new";

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        UpdateTab();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        var prev = _currentTab;
        UpdateTab();
        if (_currentTab != prev)
            InvokeAsync(StateHasChanged);
    }

    private void UpdateTab()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("tab", out var tab))
            _currentTab = tab.ToString();
        else if (uri.AbsolutePath.StartsWith("/game"))
            _currentTab = "new";
        else
            _currentTab = "";
    }

    private string ActiveClass(string tab) =>
        _currentTab == tab ? "nav-active" : "";

    private void Navigate(string url)
    {
        Nav.NavigateTo(url);
    }

    private void Logout()
    {
        AuthState.Logout();
        Nav.NavigateTo("/");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
