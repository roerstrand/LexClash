@page "/register"
@using OrdSpel.Shared.AuthDTOs
@using OrdSpel.UI.Services
@inject HttpService HttpService
@inject NavigationManager Navigation

<PageTitle>LexDuel — Registrera</PageTitle>

<div style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#1e1e2e;">
    <div style="width:360px;">

        <div style="margin-bottom:2.5rem;">
            <a href="/" style="font-size:0.78rem;text-transform:uppercase;letter-spacing:0.08em;color:#9999bb;text-decoration:none;">← Tillbaka</a>
            <div style="font-family:'JetBrains Mono',monospace;font-size:1.4rem;font-weight:700;letter-spacing:0.04em;color:#e8e8f0;margin-top:1rem;">Skapa konto</div>
        </div>

        <form @onsubmit="HandleRegister" @onsubmit:preventDefault>
            <div style="margin-bottom:1rem;">
                <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;color:#9999bb;margin-bottom:0.4rem;">Användarnamn</label>
                <input class="form-control" @bind="registerDto.Username" type="text" placeholder="användarnamn"
                       style="background:#2a2a3e;border:1px solid #44445a;color:#e8e8f0;padding:0.6rem 0.75rem;" />
            </div>

            <div style="margin-bottom:1rem;">
                <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;color:#9999bb;margin-bottom:0.4rem;">Lösenord</label>
                <input class="form-control" @bind="registerDto.Password" type="password" placeholder="••••••"
                       style="background:#2a2a3e;border:1px solid #44445a;color:#e8e8f0;padding:0.6rem 0.75rem;" />
            </div>

            <div style="margin-bottom:1.5rem;">
                <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;color:#9999bb;margin-bottom:0.4rem;">Bekräfta lösenord</label>
                <input class="form-control" @bind="registerDto.ConfirmPassword" type="password" placeholder="••••••"
                       style="background:#2a2a3e;border:1px solid #44445a;color:#e8e8f0;padding:0.6rem 0.75rem;" />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" style="margin-bottom:1rem;">@errorMessage</div>
            }

            <button type="submit" class="btn btn-primary" style="width:100%;padding:0.65rem;">
                Skapa konto
            </button>
        </form>
    </div>
</div>

@code {
    private RegisterDto registerDto = new();
    private string errorMessage = "";

    private async Task HandleRegister()
    {
        if (string.IsNullOrWhiteSpace(registerDto.Username) ||
            string.IsNullOrWhiteSpace(registerDto.Password) ||
            string.IsNullOrWhiteSpace(registerDto.ConfirmPassword))
        {
            errorMessage = "Fyll i alla fält.";
            return;
        }

        if (registerDto.Password != registerDto.ConfirmPassword)
        {
            errorMessage = "Lösenorden matchar inte.";
            return;
        }

        var result = await HttpService.RegisterUser(registerDto);

        if (result.Success)
            Navigation.NavigateTo("/");
        else
            errorMessage = result.ErrorMessage ?? "Något gick fel.";
    }
}
