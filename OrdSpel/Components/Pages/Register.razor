@page "/register"
@using OrdSpel.Shared.AuthDTOs
@using OrdSpel.UI.Services
@inject HttpService HttpService
@inject NavigationManager Navigation

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card p-4 shadow" style="width: 400px">
        <h2 class="card-title text-center mb-4">Registrera</h2>

        <form @onsubmit="HandleRegister" @onsubmit:preventDefault>
            <div class="mb-3">
                <label class="form-label">Användarnamn</label>
                <input class="form-control" @bind="registerDto.Username" type="text" placeholder="Användarnamn" />
            </div>

            <div class="mb-3">
                <label class="form-label">Lösenord</label>
                <input class="form-control" @bind="registerDto.Password" type="password" placeholder="Lösenord" />
            </div>

            <div class="mb-3">
                <label class="form-label">Bekräfta lösenord</label>
                <input class="form-control" @bind="registerDto.ConfirmPassword" type="password" placeholder="Bekräfta lösenord" />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <button type="submit" class="btn btn-primary w-100">Registrera</button>
        </form>

    </div>
</div>

@code
{
    private RegisterDto registerDto = new();
    private string errorMessage = "";

    private async Task HandleRegister()
    {
        if (string.IsNullOrWhiteSpace(registerDto.Username) ||
            string.IsNullOrWhiteSpace(registerDto.Password) ||
            string.IsNullOrWhiteSpace(registerDto.ConfirmPassword))
        {
            errorMessage = "Vänligen fyll i alla fält.";
            return;
        }

        if (registerDto.Password != registerDto.ConfirmPassword)
        {
            errorMessage = "Lösenorden matchar inte.";
            return;
        }

        var result = await HttpService.RegisterUser(registerDto);

        if (result.Success)
            Navigation.NavigateTo("/");
        else
            errorMessage = result.ErrorMessage ?? "Något gick fel.";
    }

 }
