@page "/"
@using OrdSpel.Shared.AuthDTOs
@using OrdSpel.UI.Services

@inject HttpService HttpService
@inject NavigationManager NavigationManager
@inject AuthStateService AuthState

<PageTitle>LexClash</PageTitle>

<div class="auth-page">
    <div class="auth-card">

        <div style="margin-bottom:2.5rem;text-align:center;">
            <div style="font-family:'Fondamento',serif;font-size:2.2rem;font-weight:700;letter-spacing:0.06em;color:var(--text);margin-bottom:0.25rem;">LexClash</div>
            <div style="color:var(--muted);font-size:0.82rem;text-transform:uppercase;letter-spacing:0.12em;">Word Duel</div>
        </div>

        <form @onsubmit="LoginUser" @onsubmit:preventDefault>
            <div style="margin-bottom:1.1rem;">
                <label class="form-label" style="display:block;margin-bottom:0.4rem;">Username</label>
                <input id="username"
                       class="form-control"
                       @bind="_enteredUsername"
                       type="text"
                       placeholder="username" />
            </div>

            <div style="margin-bottom:1.75rem;">
                <label class="form-label" style="display:block;margin-bottom:0.4rem;">Password</label>
                <input id="password"
                       class="form-control"
                       @bind="_enteredPassword"
                       type="password"
                       placeholder="••••••" />
            </div>

            @if (!string.IsNullOrEmpty(DisplayBox))
            {
                <div class="alert alert-danger" style="margin-bottom:1rem;">@DisplayBox</div>
            }

            <button id="submitLogin" type="submit" class="btn btn-primary" style="width:100%;">
                Log in
            </button>
        </form>

        <div style="margin-top:1.5rem;text-align:center;font-size:0.9rem;color:var(--muted);">
            No account? <a href="/register" style="color:var(--accent);text-decoration:none;">Sign up</a>
        </div>
    </div>
</div>

@code {
    private string DisplayBox { get; set; } = string.Empty;
    private string _enteredUsername = string.Empty;
    private string? _enteredPassword = null;

    public async Task LoginUser()
    {
        if (string.IsNullOrWhiteSpace(_enteredUsername) ||
            string.IsNullOrWhiteSpace(_enteredPassword))
        {
            DisplayBox = "Please enter your username and password.";
            return;
        }

        var loginDto = new LoginDto
        {
            Username = _enteredUsername,
            Password = _enteredPassword!
        };

        var result = await HttpService.LoginUser(loginDto);

        if (!result.Success)
        {
            DisplayBox = "Incorrect username or password.";
            await Task.Delay(3000);
            DisplayBox = string.Empty;
            return;
        }

        NavigationManager.NavigateTo("/game");
    }
}
