@page "/"
@using OrdSpel.Shared.AuthDTOs
@using OrdSpel.UI.Services

@inject HttpService HttpService
@inject NavigationManager NavigationManager
@inject AuthStateService AuthState

<PageTitle>LexDuel</PageTitle>

<div style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#1e1e2e;">
    <div style="width:360px;">

        <div style="margin-bottom:2.5rem;text-align:center;">
            <div style="font-family:'JetBrains Mono',monospace;font-size:2rem;font-weight:700;letter-spacing:0.04em;color:#e8e8f0;margin-bottom:0.25rem;">LexDuel</div>
            <div style="color:#6666aa;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;">Ordduell</div>
        </div>

        <form @onsubmit="LoginUser" @onsubmit:preventDefault>
            <div style="margin-bottom:1rem;">
                <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;color:#9999bb;margin-bottom:0.4rem;">Användarnamn</label>
                <input id="username"
                       class="form-control"
                       @bind="_enteredUsername"
                       type="text"
                       placeholder="användarnamn"
                       style="background:#2a2a3e;border:1px solid #6666aa45a;color:#e8e8f0;padding:0.6rem 0.75rem;" />
            </div>

            <div style="margin-bottom:1.5rem;">
                <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;color:#9999bb;margin-bottom:0.4rem;">Lösenord</label>
                <input id="password"
                       class="form-control"
                       @bind="_enteredPassword"
                       type="password"
                       placeholder="••••••"
                       style="background:#2a2a3e;border:1px solid #6666aa45a;color:#e8e8f0;padding:0.6rem 0.75rem;" />
            </div>

            @if (!string.IsNullOrEmpty(DisplayBox))
            {
                <div class="alert alert-danger" style="margin-bottom:1rem;">@DisplayBox</div>
            }

            <button id="submitLogin" type="submit" class="btn btn-primary" style="width:100%;padding:0.65rem;">
                Logga in
            </button>
        </form>

        <div style="margin-top:1.5rem;text-align:center;font-size:0.82rem;color:#6666aa;">
            Inget konto? <a href="/register" style="color:#888;text-decoration:none;border-bottom:1px solid #333;">Registrera dig</a>
        </div>
    </div>
</div>

@code {
    private string DisplayBox { get; set; } = string.Empty;
    private string _enteredUsername = string.Empty;
    private string? _enteredPassword = null;

    public async Task LoginUser()
    {
        if (string.IsNullOrWhiteSpace(_enteredUsername) ||
            string.IsNullOrWhiteSpace(_enteredPassword))
        {
            DisplayBox = "Fyll i användarnamn och lösenord.";
            return;
        }

        var loginDto = new LoginDto
        {
            Username = _enteredUsername,
            Password = _enteredPassword!
        };

        var result = await HttpService.LoginUser(loginDto);

        if (!result.Success)
        {
            DisplayBox = "Fel användarnamn eller lösenord.";
            await Task.Delay(3000);
            DisplayBox = string.Empty;
            return;
        }

        NavigationManager.NavigateTo("/game");
    }
}
