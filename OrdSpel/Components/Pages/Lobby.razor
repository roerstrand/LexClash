@page "/lobby/{Code}"
@page "/lobby"
@using OrdSpel.Shared.DTOs

@* For creating realtime HubConnection *@
@using Microsoft.AspNetCore.SignalR.Client 


@inject OrdSpel.UI.Services.GameLobbyApiService LobbyApi
@inject NavigationManager Navigation

@* This component performs “async disposal.” *@
@* It is used to close the SignalR connection and cancel polling when leaving the page, so that no resources remain hanging. *@
@implements IAsyncDisposable





<div class="container mt-4">
    <h2>Spellobby</h2>

    @if (!string.IsNullOrWhiteSpace(Code))
    {
        <div class="mb-3">
            <div><strong>Spelkod:</strong> @Code</div>
            <div><strong>Status:</strong> @_lobbyStatus?.Status</div>
            <div><strong>Spelare:</strong> @_lobbyStatus?.PlayerCount / @_lobbyStatus?.MaxPlayers</div>
        </div>
    }

  @*   Input Code *@
    @if (string.IsNullOrWhiteSpace(Code))
    {
    <p class="text-muted">Ange en spelkod för att fortsätta.</p>

    <div class="input-group" style="max-width: 420px;">
        <input class="form-control" placeholder="Spelkod" @bind="_enteredCode" @bind:event="oninput" />
        <button class="btn btn-primary" @onclick="GoToLobby">Gå</button>
    </div>


    <div class="form-text">Exempel: <code>ABC123</code></div>
    }
    else if (_isLoading)
    {
        <p class="text-muted">Laddar lobbystatus...</p>
    }
    else if (_lobbyStatus is null)
    {
        <p class="text-danger">Hittade ingen spelsession för den här koden.</p>
    }
    else if (_lobbyStatus.IsReadyToStart)
    {
        <p class="text-success">Redo att starta!</p>
    }
    else
    {
        <p class="text-muted">Väntar på motspelare...</p>
    }
</div>









@code {
    [Parameter]
    public string Code { get; set; } = string.Empty; // Get from URL

    private GameLobbyStatusDto? _lobbyStatus;   // Holds the current lobby status from the API
    private bool _isLoading = true;             // Used to show loading state while fetching lobby status

    private string _enteredCode = string.Empty;

    private HubConnection? _hubConnection;      // Keeps the SignalR connection for real-time updates
    private CancellationTokenSource? _pollCts;  // Used to cancel the polling loop if SignalR connection fails



    // 1. When accesing the page first time or when the URL parameter changes,
    // we need to fetch the lobby status and set up the SignalR connection.
    protected override async Task OnParametersSetAsync()
    {
        // Stop any existing polling and close existing SignalR connection before starting a new one
        await StopPollingAsync();
        await DisposeHubAsync();

        // Fetch the initial lobby status from the API
        _isLoading = true;
        _lobbyStatus = await LobbyApi.GetLobbyStatusAsync(Code);
        _isLoading = false;

        // If game already started when entering lobby, go straight to game
        if (_lobbyStatus?.Status == OrdSpel.Shared.GameStatus.InProgress)
        {
            Navigation.NavigateTo($"/game/{Code}");
            return;
        }

        // Start the SignalR connection to receive real-time updates about the lobby status
        // (If it fails, we will fall back to polling)
        await StartHubAsync();
    }



    // 2. This method sets up the SignalR connection to the server and subscribes to lobby updates(listen to event).
    private async Task StartHubAsync()
    {
        if (string.IsNullOrWhiteSpace(Code))
        {
            return;
        }

        // If there is code >  Create a new HubConnection to the server's "hubs/game" endpoint
        // Try to reconnect automatically if the connection is lost
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(new Uri(new Uri(Navigation.BaseUri), "hubs/game"))
            .WithAutomaticReconnect()
            .Build();

        // It listens to the "LobbyUpdated" event from the server, 
        // and when it receives an update for the current lobby code, it fetches the latest lobby status from the API and updates the UI.
        _hubConnection.On("LobbyUpdated", async (string gameCode) =>
        {
            // If code matches the current lobby code, fetch the latest lobby status and update the UI
            if (string.Equals(gameCode, Code, StringComparison.OrdinalIgnoreCase))
            {
                _lobbyStatus = await LobbyApi.GetLobbyStatusAsync(Code);

                if (_lobbyStatus?.Status == OrdSpel.Shared.GameStatus.InProgress)
                {
                    await InvokeAsync(() => Navigation.NavigateTo($"/game/{Code}"));
                    return;
                }

                await InvokeAsync(StateHasChanged);
            }
        });


        // When reconnected, stop any existing polling (in case it was running) 
        // and fetch the latest lobby status to update the UI.
        _hubConnection.Reconnected += async _ =>
        {
            await StopPollingAsync();
            _lobbyStatus = await LobbyApi.GetLobbyStatusAsync(Code);
            await InvokeAsync(StateHasChanged);
        };


        // If the connection is lost  >  Start polling as a fallback to keep updating the lobby status 
        // until the connection can be re-established.
        _hubConnection.Closed += async _ =>
        {
            await StartPollingAsync();
        };

        try
        {
            // Try to start connection and join the lobby group on the server using the lobby code.
            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("JoinGame", Code);
        }
        catch
        {
            // If starting the connection or joining the lobby group fails, start polling as a fallback.
            await StartPollingAsync();
        }
    }



    // 3. Close and dispose the SignalR connection when leaving the page or when the URL parameter changes,
    //  to free up resources and stop receiving updates.
    private async Task DisposeHubAsync()
    {
        if (_hubConnection is null)
        {
            return;
        }

        try
        {
            await _hubConnection.DisposeAsync();
        }
        finally
        {
            _hubConnection = null;
        }
    }


    // 4. Stop Polling: Cancel loop and clear token
    private Task StopPollingAsync()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollCts = null;
        return Task.CompletedTask;
    }


    // 5. 
    private async Task StartPollingAsync()
    {
        // If we are already polling, do not start another loop
        if (_pollCts is not null)
        {
            return;
        }

        // Create CancellationTokenSource to control the loop, for stopping polling loop from other methods 
        // (like when SignalR connection is re-established or when leaving the page)
        _pollCts = new CancellationTokenSource();
        var ct = _pollCts.Token;

        try
        {
            // Wait  for 3 seconds btween each API call or until the token is cancelled, 
            // and fetch the latest lobby status to update the UI.
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(3));
            while (await timer.WaitForNextTickAsync(ct))
            {
                _lobbyStatus = await LobbyApi.GetLobbyStatusAsync(Code, ct);

                if (_lobbyStatus?.Status == OrdSpel.Shared.GameStatus.InProgress)
                {
                    await InvokeAsync(() => Navigation.NavigateTo($"/game/{Code}"));
                    return;
                }

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Expected when the token is cancelled, just exit the loop and not throw an error
        }
    }


    // 6. This method is called when the component is being disposed (e.g., when navigating away from the page).
    public async ValueTask DisposeAsync()
    {
        await StopPollingAsync();
        await DisposeHubAsync();
    }

    private void GoToLobby()
    {
        var trimmed = _enteredCode.Trim();
        if (string.IsNullOrWhiteSpace(trimmed))
        {
            return;
        }

        Navigation.NavigateTo($"/lobby/{Uri.EscapeDataString(trimmed)}");
    }
}
