@page "/game"
@page "/game/{Code}"
@using OrdSpel.Shared.Constraints
@using OrdSpel.UI.Components.Game
@using OrdSpel.UI.Services
@using OrdSpel.Shared.DTOs
@using OrdSpel.Shared.GameDTOs
@using OrdSpel.Shared.Enums
@using Microsoft.AspNetCore.SignalR.Client
@inject AuthStateService AuthState
@inject NavigationManager NavigationManager
@inject GameLobbyApiService LobbyService
@inject GameService GameService
@inject IConfiguration Configuration

@implements IAsyncDisposable

<div class="page-wrapper">

@if (_checkingActiveGame)
{
    <p class="text-muted">Loading...</p>
}
else if (string.IsNullOrEmpty(Code))
{
    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <button class="nav-link @(_tab == "new" ? "active" : "")" @onclick='() => SetTab("new")'>New game</button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(_tab == "active" ? "active" : "")" @onclick='() => SetTab("active")'>Active games</button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(_tab == "history" ? "active" : "")" @onclick='() => SetTab("history")'>Saved games</button>
        </li>
    </ul>

    @if (_tab == "new")
    {
        <GameEntry />
    }
    else if (_tab == "active")
    {
        @if (_activeGame == null)
        {
            <p class="text-muted">No active game.</p>
        }
        else
        {
            <div style="
                background: radial-gradient(ellipse 130% 70% at 50% -10%, rgba(184,212,227,0.4) 0%, transparent 60%), rgba(255,255,255,0.88);
                backdrop-filter: blur(12px);
                border: 1px solid rgba(255,255,255,0.72);
                border-radius: var(--radius);
                padding: 1.5rem;
                box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 2px 8px rgba(102,16,31,0.09), 0 8px 28px rgba(102,16,31,0.12);
            ">
                <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.75rem;">
                    <span class="game-code" style="font-size:1.6rem;">@_activeGame.GameCode</span>
                    <span class="badge bg-primary">@_activeGame.Status</span>
                </div>
                <p class="text-muted" style="margin:0.75rem 0 1.25rem;">Start word: <strong>@_activeGame.StartWord</strong></p>
                <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
                    <button class="btn btn-primary btn-sm" @onclick='() => NavigationManager.NavigateTo($"/game/{_activeGame.GameCode}")'>
                        Go to game
                    </button>
                    <button class="btn btn-outline-danger btn-sm" @onclick="LeaveActiveGame" disabled="@_activeGameBusy">
                        @(_activeGameBusy ? "Leaving..." : "Leave game")
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_activeGameError))
                {
                    <div class="alert alert-danger" style="margin-top:0.75rem;">@_activeGameError</div>
                }
            </div>
        }
    }
    else
    {
        <SavedGames />
    }
}
else if (_status == null && _loadError == null)
{
    <p class="text-muted">Loading...</p>
}
else if (_status == null && _loadError != null)
{
    <p class="text-danger">Error loading: @_loadError</p>
}
else if (_status.Status == GameStatus.WaitingForPlayers)
{
    <div style="display:flex;gap:0.75rem;margin-bottom:1.5rem;flex-wrap:wrap;">
        <button class="btn btn-outline-secondary btn-sm" @onclick='() => NavigationManager.NavigateTo("/game")'>← Home</button>
        <button class="btn btn-outline-danger btn-sm" @onclick="LeaveGame">Leave game</button>
    </div>
    <Lobby GameCode="@Code" Status="@_status" OnStart="HandleStart" />
}
else if (_status.Status == GameStatus.InProgress)
{
    <div style="display:flex;gap:0.75rem;margin-bottom:1.5rem;flex-wrap:wrap;">
        <button class="btn btn-outline-secondary btn-sm" @onclick='() => NavigationManager.NavigateTo("/game")'>← Home</button>
        <button class="btn btn-outline-danger btn-sm" @onclick="LeaveGame">Leave game</button>
    </div>
    <ActiveGame GameCode="@Code" />
}
else if (_status.Status == GameStatus.GameFinished)
{
    <div style="margin-bottom:1.5rem;">
        <button class="btn btn-outline-secondary btn-sm" @onclick='() => NavigationManager.NavigateTo("/game")'>← Home</button>
    </div>
    <GameResult GameCode="@Code" />
}

<LetterScoreCard Scores="@LetterScores.Scores" ShowRules="@_showRules" />

</div>

@code {
    [Parameter]
    public string? Code { get; set; }

    private GameLobbyStatusDto? _status;
    private HubConnection? _hubConnection;
    private CancellationTokenSource? _pollCts;
    private bool _checkingActiveGame;
    private string? _loadError;
    private string? _activeGameCode;
    private GameSessionResponseDto? _activeGame;
    private string _tab = "new";
    private bool _showRules = true;
    private bool _activeGameBusy;
    private string? _activeGameError;

    protected override void OnInitialized()
    {
        if (!AuthState.IsLoggedIn)
            NavigationManager.NavigateTo("/");

    }

    private void SetTab(string tab)
    {
        _tab = tab;
        _activeGameError = null;
    }

    protected override async Task OnParametersSetAsync()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("tab", out var tabValue))
        {
            var tab = tabValue.ToString();

            if (tab == "history")
                _tab = "history";
            else if (tab == "active")
                _tab = "active";
        }

        _showRules = string.IsNullOrWhiteSpace(Code);

        await StopPollingAsync();
        await DisposeHubAsync();

        _checkingActiveGame = false;

        if (string.IsNullOrWhiteSpace(Code))
        {
            _status = null;
            _activeGameCode = null;

            _checkingActiveGame = true;
            try
            {
                var activeGame = await GameService.GetActiveGameAsync();
                if (activeGame != null)
                {
                    _activeGameCode = activeGame.GameCode;
                    _activeGame = activeGame;
                }
                else
                {
                    _activeGame = null;
                }
            }
            catch { }
            _checkingActiveGame = false;
            return;
        }

        await RefreshStatusAsync();
        await StartHubAsync();
    }

    private async Task RefreshStatusAsync()
    {
        try
        {
            _loadError = null;
            _status = await LobbyService.GetLobbyStatusAsync(Code!);
            if (_status == null)
                _loadError = $"Lobby API returned null for code '{Code}'.";
        }
        catch (Exception ex)
        {
            _status = null;
            _loadError = $"{ex.GetType().Name}: {ex.Message}";
        }
    }

    private async Task LeaveActiveGame()
    {
        if (_activeGame == null) return;
        _activeGameBusy = true;
        _activeGameError = null;
        try
        {
            await GameService.EndGameAsync(_activeGame.GameCode);
            _activeGame = null;
            _activeGameCode = null;
        }
        catch
        {
            _activeGameError = "Could not leave game. Please try again.";
        }
        finally
        {
            _activeGameBusy = false;
        }
    }

    private async Task LeaveGame()
    {
        if (string.IsNullOrWhiteSpace(Code))
            return;

        try
        {
            await GameService.EndGameAsync(Code);
        }
        catch { }

        await StopPollingAsync();
        await DisposeHubAsync();
        _status = null;
        NavigationManager.NavigateTo("/game", forceLoad: false, replace: true);
    }

    private async Task HandleStart()
    {
        await RefreshStatusAsync();
        StateHasChanged();
    }

    // --- SignalR med polling-fallback ---

    private async Task StartHubAsync()
    {
        if (string.IsNullOrWhiteSpace(Code))
            return;

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(new Uri(new Uri(Configuration["ConnectionStrings:ApiBaseUrl"]!), "hubs/game"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On("LobbyUpdated", async (string gameCode) =>
        {
            if (string.Equals(gameCode, Code, StringComparison.OrdinalIgnoreCase))
            {
                await RefreshStatusAsync();
                await InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.On("TurnUpdated", async (string gameCode) =>
        {
            if (string.Equals(gameCode, Code, StringComparison.OrdinalIgnoreCase))
            {
                await RefreshStatusAsync();
                await InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.Reconnected += async _ =>
        {
            await StopPollingAsync();
            await RefreshStatusAsync();
            await InvokeAsync(StateHasChanged);
        };

        _hubConnection.Closed += async _ =>
        {
            await StartPollingAsync();
        };

        try
        {
            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("JoinGame", Code);
        }
        catch
        {
            await StartPollingAsync();
        }
    }

    private async Task StartPollingAsync()
    {
        if (_pollCts is not null)
            return;

        _pollCts = new CancellationTokenSource();
        var ct = _pollCts.Token;

        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(3));
            while (await timer.WaitForNextTickAsync(ct))
            {
                await RefreshStatusAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private Task StopPollingAsync()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollCts = null;
        return Task.CompletedTask;
    }

    private async Task DisposeHubAsync()
    {
        if (_hubConnection is null)
            return;

        try { await _hubConnection.DisposeAsync(); }
        finally { _hubConnection = null; }
    }

    public async ValueTask DisposeAsync()
    {
        await StopPollingAsync();
        await DisposeHubAsync();
    }

    private void HandleGameCreated()
    {
        _showRules = false;
    }
}
